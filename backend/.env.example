# ===========================================
# Vibe Onepage - Environment Variables
# ===========================================
# Copy this file to .env and fill in values
# DO NOT commit .env to version control!

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=onepage
DB_USERNAME=root
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ (optional - for AI features)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# JWT Authentication (REQUIRED in production)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-production-secret-at-least-32-characters
JWT_EXPIRATION=604800000        # 7 days in milliseconds
JWT_REFRESH_EXPIRATION=2592000000  # 30 days in milliseconds

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload
UPLOAD_PATH=./uploads

# Server
APP_HOST=0.0.0.0
APP_PORT=8080
